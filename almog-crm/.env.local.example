# Supabase — copy from your project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Anthropic — for the AI agents proxy
ANTHROPIC_API_KEY=sk-ant-...

# CRM — simple password gate (no full auth needed for MVP)
CRM_PASSWORD=your_admin_password_here

# Optional: Resend for email notifications
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL=almog@example.com
